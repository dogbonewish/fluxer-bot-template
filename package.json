{
  "name": "fluxer-bot-template",
  "version": "1.0.0",
  "description": "A starter template for building bots with @fluxerjs/core — includes a custom command handler, event handler, and project structure.",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "build:clean": "rimraf build/ && npm run build",
    "start": "node build/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/"
  },
  "keywords": [
    "fluxer",
    "bot",
    "template",
    "fluxerjs"
  ],
  "author": "dogbonewish",
  "license": "MIT",
  "dependencies": {
    "@fluxerjs/core": "^1.3.1",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
